@using System.Text.Json
@using Namezr.Client
@using Namezr.Client.Shared
@using Namzer.BlazorPortals

@inject IConfiguration Configuration

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/"/>

    <script>
        function @(ClientSentryBootstrap.FunctionName)() {
            return @SentryDsnLiteral;
        }
    </script>

    <link href="@Assets["_content/Havit.Blazor.Components.Web.Bootstrap/bootstrap.min.css"]" rel="stylesheet"/>

    <link rel="stylesheet" href="@Assets["app.css"]"/>
    <link rel="stylesheet" href="@Assets["Namezr.styles.css"]"/>

    @* TODO: conditional? @Assets? *@
    <link href="_content/BlazorColorPicker/colorpicker.css" rel="stylesheet"/>

    <ImportMap/>

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">

    <style>
        .wasm-loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(13, 17, 23, 0.95);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            flex-direction: column;
            gap: 1rem;
        }

        .wasm-loading-spinner {
            width: 3rem;
            height: 3rem;
            border: 0.3rem solid rgba(108, 117, 125, 0.3);
            border-top: 0.3rem solid #0d6efd;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        .wasm-loading-text {
            color: #dee2e6;
            font-size: 1.1rem;
            font-weight: 500;
        }

        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .wasm-loading-overlay.hidden {
            display: none;
        }
    </style>

    <HeadOutlet/>
</head>

<body>

<!-- WASM Loading Indicator -->
<div id="wasm-loading" class="wasm-loading-overlay" aria-label="Loading application">
    <div class="wasm-loading-spinner" role="status" aria-hidden="true"></div>
    <div class="wasm-loading-text">Loading interactive features...</div>
</div>

<Routes/>
<BodyEndOutlet @rendermode="InteractiveWebAssembly" />

<script src="_framework/blazor.web.js"></script>
<script>
    // Hide the loading indicator when WASM is ready
    Blazor.addEventListener('enhancedload', function () {
        const loadingElement = document.getElementById('wasm-loading');
        if (loadingElement) {
            loadingElement.classList.add('hidden');
        }
    });

    // Fallback: Hide loading indicator when the first WASM component starts
    // This covers cases where enhancedload might not fire consistently
    document.addEventListener('DOMContentLoaded', function() {
        // Wait a bit for WASM to initialize
        setTimeout(function() {
            const wasmElements = document.querySelectorAll('[blazor-component-id]');
            if (wasmElements.length > 0) {
                const loadingElement = document.getElementById('wasm-loading');
                if (loadingElement) {
                    loadingElement.classList.add('hidden');
                }
            } else {
                // If no WASM components found, hide after a reasonable timeout
                setTimeout(function() {
                    const loadingElement = document.getElementById('wasm-loading');
                    if (loadingElement) {
                        loadingElement.classList.add('hidden');
                    }
                }, 3000); // 3 second fallback timeout
            }
        }, 1000); // 1 second initial delay
    });
</script>
@((MarkupString)HxSetup.RenderBootstrapJavaScriptReference())
<WasmTrigger/>

<BlazorColorPicker.ColorPicker @rendermode="InteractiveWebAssembly" />

@* Fancybox *@
<script src="@Assets["lib/fancybox/5.0.36/fancybox.umd.js"]"></script>
<link href="@Assets["lib/fancybox/5.0.36/fancybox.css"]" rel="stylesheet"/>
<script>
    Fancybox.bind("[data-fancybox]", {
        // Causes a page refresh when closing the gallery
        Hash: false,
    });
</script>
</body>

</html>

@code {

    private MarkupString SentryDsnLiteral
    {
        get
        {
            string? value = Configuration.GetValue<string?>("Sentry:ClientDsn");

            // The case is safe since we are inlining the result as JS literal.
            // And since JSON is a subset of JS literal, we are safe to not worry about escaping/escaping/etc.
            return (MarkupString)JsonSerializer.Serialize(value);
        }
    }

}